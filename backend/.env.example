# ── Aplicação ─────────────────────────────────────────────────────────────
DEBUG=True

# ── Base de dados ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./helpdesk.db

# ── JWT ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── SMTP (Mailpit local por defeito) ──────────────────────────────────────
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=helpdesk@localhost

# ── IMAP (Mailpit local por defeito) ──────────────────────────────────────
IMAP_ENABLED=False
IMAP_SERVER=localhost
IMAP_PORT=1143
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=True
IMAP_POLLING_MINUTES=2
SLA_CHECK_MINUTES=5

# ── CORS / Frontend ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5173

EMAIL_FALLBACK_USER_EMAIL=external@helpdesk.local
